# .env.sample

# JSON completo da chave de serviço do Firebase (tudo em uma linha)
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"curriculo-d1dc4","private_key":"-----BEGIN PRIVATE KEY-----\n…\n-----END PRIVATE KEY-----\n",…}'

# URL do Realtime Database
FIREBASE_DATABASE_URL=https://curriculo-d1dc4-default-rtdb.firebaseio.com

# ======================================
# CRM Provider (Free CRM - EspoCRM/SuiteCRM)
# ======================================
# Fallback seguro: se FREE_CRM_ENABLED=false ou FREE_CRM_BASE_URL vazio,
# o sistema continua com n8n e nao quebra fluxos.
FREE_CRM_ENABLED=false
FREE_CRM_PROVIDER=espocrm
FREE_CRM_BASE_URL=
FREE_CRM_API_KEY=
FREE_CRM_USERNAME=
FREE_CRM_PASSWORD=
FREE_CRM_TIMEOUT_MS=10000

# Endpoints padrao (podem ser ajustados conforme seu CRM)
FREE_CRM_LEAD_ENDPOINT=/api/v1/Lead
FREE_CRM_INTERACTION_ENDPOINT=/api/v1/Note

# ======================================
# WhatsApp Adapter (Evolution API)
# ======================================
# Fallback seguro: se EVOLUTION_API_ENABLED=false ou sem credenciais,
# o envio WhatsApp vira no-op seguro para nao interromper campanhas.
EVOLUTION_API_ENABLED=false
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_API_INSTANCE=default
EVOLUTION_API_TIMEOUT_MS=8000

# Opcional: workflow n8n
N8N_API_KEY=

# ======================================
# Social Listening (Meta + Twitter)
# ======================================
# Modo seguro: somente capta sinais publicos e notifica, sem envio automatico de DM.
SOCIAL_LISTENING_ENABLED=false
SOCIAL_LISTENING_INTERVAL_MINUTES=60

# Instagram / Meta Graph API
SOCIAL_INSTAGRAM_ENABLED=false
SOCIAL_INSTAGRAM_ACCESS_TOKEN=
SOCIAL_INSTAGRAM_BUSINESS_ACCOUNT_ID=
SOCIAL_INSTAGRAM_HASHTAGS=#precisodeumdesigner,#freelancer,#marketingdigitalajuda
SOCIAL_INSTAGRAM_LIMIT=10

# Twitter API v2
SOCIAL_TWITTER_ENABLED=false
SOCIAL_TWITTER_BEARER_TOKEN=
SOCIAL_TWITTER_QUERY=("preciso de" (freelancer OR designer OR "social media" OR desenvolvedor) -is:retweet -is:reply) lang:pt
SOCIAL_TWITTER_LIMIT=15

# Fila de aprovacao manual antes de notificar (recomendado)
SOCIAL_REQUIRE_MANUAL_APPROVAL=true

# Alertas apos captacao/aprovacao de lead
SOCIAL_SLACK_WEBHOOK_URL=
SOCIAL_TELEGRAM_BOT_TOKEN=
SOCIAL_TELEGRAM_CHAT_ID=
